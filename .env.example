# Set to "production" to enforce the full security posture (secure cookies, HSTS,
# SSL redirect) and require a PostgreSQL DATABASE_URL + real SECRET_KEY/ALLOWED_HOSTS.
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_CSRF_TRUSTED_ORIGINS=
# Comma-separated allow-list of cross-origin API callers (empty = same-origin only).
DJANGO_CORS_ALLOWED_ORIGINS=
# PostgreSQL is required in production (ADR-0001). SQLite is dev/test only.
DATABASE_URL=postgres://commerce:commerce@db:5432/commerce

# Simulated-gateway test modes (decline/dropped_confirmation). Auto-disabled in prod.
GATEWAY_TEST_MODES_ENABLED=1
# Max product-image upload size in bytes (default 5 MiB).
MAX_UPLOAD_SIZE_BYTES=5242880

# Email (transactional order emails, password reset, verification). Dev = console backend.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@aster-commerce.test
# Absolute base URL used to build links inside emails (no request context in workers).
DJANGO_SITE_URL=http://localhost:8000
# Auth throttles
THROTTLE_PASSWORD_RESET=5/min

# Observability / rate limiting
DJANGO_LOG_LEVEL=INFO
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_CHECKOUT=20/min
THROTTLE_PAYMENT=20/min
THROTTLE_REFUND=30/min
THROTTLE_LOGIN=10/min
