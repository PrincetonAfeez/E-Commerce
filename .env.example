# Set to "production" to enforce the full security posture (secure cookies, HSTS,
# SSL redirect) and require a PostgreSQL DATABASE_URL + real SECRET_KEY/ALLOWED_HOSTS.
DJANGO_ENV=development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_CSRF_TRUSTED_ORIGINS=
# Comma-separated allow-list of cross-origin API callers (empty = same-origin only).
DJANGO_CORS_ALLOWED_ORIGINS=
# PostgreSQL is required in production (ADR-0001). SQLite is dev/test only.
DATABASE_URL=postgres://commerce:commerce@db:5432/commerce

# Production media: S3 bucket required unless explicitly opting into local disk.
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_MEDIA_LOCATION=media
# MEDIA_PERSIST_LOCAL=0

# Run database migrations on container boot (set on the web service only).
# RUN_MIGRATIONS=1

# Simulated-gateway test modes (decline/dropped_confirmation). Auto-disabled in prod.
# Do NOT set GATEWAY_TEST_MODES_ENABLED=1 when DJANGO_ENV=production.
GATEWAY_TEST_MODES_ENABLED=1
# Max product-image upload size in bytes (default 5 MiB).
MAX_UPLOAD_SIZE_BYTES=5242880

# Email (transactional order emails, password reset, verification). Dev = console backend.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@aster-commerce.test
# Absolute base URL used to build links inside emails (no request context in workers).
DJANGO_SITE_URL=http://localhost:8000
# Auth throttles
THROTTLE_PASSWORD_RESET=5/min
THROTTLE_STORE_SIGNUP=5/h
THROTTLE_GUEST_ORDER_LOOKUP=10/h
THROTTLE_RESEND_VERIFICATION=3/h

# Production: shared cache for rate limits (Redis recommended).
# CACHE_URL=redis://redis:6379/0
# DATABASE_CONN_MAX_AGE=600

# Feature flags (1/on/true enables; 0/off disables). See shop/feature_flags.py.
# FF_SELF_SERVE_SIGNUP=1
# FF_ABANDONED_CART_RECOVERY=1
# FF_SUBSCRIPTION_BILLING=1

# Production SMTP (required when DJANGO_EMAIL_BACKEND is SMTP).
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=
# DJANGO_EMAIL_HOST_PASSWORD=
# DJANGO_EMAIL_USE_TLS=1

# Slug-based tenant routing on platform subdomains (comma-separated).
# TENANT_PLATFORM_DOMAINS=aster-commerce.test

# Active payment gateway adapter (simulated by default).
# PAYMENT_GATEWAY=simulated

# Inbound PSP webhook HMAC secret (required when processing webhooks in production).
# PAYMENT_WEBHOOK_SECRET=change-me-in-production

# Internal ops metrics endpoint secret (required in production).
# OPS_METRICS_SECRET=change-me-in-production

# Off-host backup shipping (optional; requires aws CLI in the backup container).
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_S3_PREFIX=db

# Production tenancy / security (defaults shown for reference).
# REQUIRE_TENANT_CONTEXT=1
# TLS_CHECK_SECRET=change-me-in-production
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production

# Observability / rate limiting
DJANGO_LOG_LEVEL=INFO
THROTTLE_ANON=60/min
THROTTLE_USER=240/min
THROTTLE_CHECKOUT=20/min
THROTTLE_PAYMENT=20/min
THROTTLE_REFUND=30/min
THROTTLE_LOGIN=10/min
